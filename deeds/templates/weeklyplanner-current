{% extends "layout.html" %}

{% block content %}
<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold">Weekly Step Planner</h1>
  <div class="flex space-x-4">
    <a href="{{ url_for('goals.dashboard') }}"
       class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg transition">
      Dashboard
    </a>
    <a href="{{ url_for('goals.milestone_view') }}"
       class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition">
      Milestones
    </a>
  </div>
</div>

<div class="min-h-screen flex flex-col lg:flex-row" x-data="plannerApp()">
  <!-- Goals List -->
  <div class="lg:w-1/3 w-full p-4 space-y-4 overflow-y-auto">
    <h2 class="text-xl font-bold mb-4">Your Current Goals</h2>

    <!-- Goal List -->
 <template x-for="goal in goals" :key="goal.id">
  <div class="bg-white rounded-xl shadow p-4 border-l-8 mb-2" :style="`border-left-color: ${goal.color}`">
    <!-- Goal Header -->
    <div @click="goal.expanded = !goal.expanded" class="cursor-pointer flex justify-between items-center">
      <div>
        <h3 class="text-lg font-semibold" x-text="goal.name"></h3>
        <p class="text-sm text-gray-500 italic" x-text="goal.motivation"></p>
      </div>
      <div class="text-sm text-blue-500" x-text="goal.expanded ? '−' : '+'"></div>
    </div>

    <!-- Milestone List -->
    <div x-show="goal.expanded" class="mt-2 pl-4 space-y-1">
      <template x-if="!goal.milestones || goal.milestones.length === 0">
        <div class="text-sm text-gray-400 italic">No milestones</div>
      </template>
      <template x-for="milestone in goal.milestones" :key="milestone.id">
        <div
          @click="selectMilestone(goal, milestone)"
          class="cursor-pointer p-2 rounded hover:bg-gray-100 border"
          :class="{ 'bg-blue-100': selectedMilestone?.id === milestone.id }"
        >
          <span class="font-medium" x-text="milestone.name"></span>
          <span class="text-xs text-gray-500 ml-2" x-text="milestone.percentage + '%'"></span>
        </div>
      </template>
    </div>
  </div>
</template>


  </div>

  <!-- Weekly Planner -->
  <div class="lg:w-2/3 w-full p-4" x-show="selectedGoal !== null" x-transition>
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-bold">🗓️ Weekly plan for <span x-text="selectedGoal?.name"></span></h2>
    </div>

    <div class="flex justify-between items-center mb-4">
      <div>
        <button
          @click="goToCurrentWeek"
          class="bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700 transition"
        >
          This Week
        </button>
      </div>
      <div class="text-lg font-semibold" x-text="`Week beginning – ${getWeekStartDateFormatted()}`"></div>
      <div class="space-x-2">
        <button @click="changeWeek(-1)" class="bg-gray-200 text-gray-800 px-3 py-1 rounded hover:bg-gray-300 transition">← Prev</button>
        <button @click="changeWeek(1)" class="bg-gray-200 text-gray-800 px-3 py-1 rounded hover:bg-gray-300 transition">Next →</button>
      </div>
    </div>

    <!-- Day Columns -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-4">
      <template x-for="day in days" :key="day.name">
        <div
          class="bg-white p-4 rounded-xl shadow min-h-[200px]"
          :class="{'border-2 border-dashed border-blue-400': dragOverDay === day.name}"
          @dragover.prevent="dragOverDay = day.name"
          @dragleave="dragOverDay = null"
          @drop="handleDrop(day.name)"
        >
          <h3 class="font-bold text-lg mb-1" x-text="day.label"></h3>
<p class="text-xs text-gray-500 mb-2" x-text="day.dateFormatted"></p>

          <!-- Steps -->
          <ul class="space-y-2 mb-2">
            <template x-for="(step, index) in weeklyPlan[day.name]" :key="step.id">
              <li
                class="rounded px-2 py-1 text-sm"
                :style="`background-color: ${selectedGoal.color};`"
                draggable="true"
                @dragstart="startDrag(day.name, index)"
              >
                <div class="flex justify-between items-center text-white">
                  <div>
                    <input type="checkbox" :checked="step.completed" @change="toggleComplete(day.name, index, $event)" class="mr-1"/>
                    <span x-text="step.title" :class="{'line-through': step.completed}"></span>
                    <span x-show="step.value !== null && step.value !== undefined" class="ml-2 text-xs">(<span x-text="step.value"></span> <span x-text="selectedGoal.metric"></span>)</span>
                  </div>
                  <button @click="removeStep(day.name, step.id)" class="text-xs hover:underline">✕</button>
                </div>
                <div x-show="step.completed">
                  <textarea
                    x-model="step.reflection"
                    @change="updateReflection(step, day.name, index)"
                    placeholder="Reflection..."
                    class="w-full mt-1 p-1 text-xs rounded"
                  ></textarea>
                </div>
              </li>
            </template>
          </ul>

          <!-- Add Step -->
          <div class="mt-2">
            <input
              type="text"
              x-model="newStep[day.name]"
              placeholder="Add step…"
              class="text-sm w-full border rounded p-1 mb-2"
            />

            <!-- Only show value input if the goal has no milestones -->
            <template x-if="selectedGoal && selectedGoal.milestones_enabled === false">
              <label class="text-xs text-gray-600 flex items-center space-x-1 mb-1">
                <input type="checkbox" x-model="repeatAllDays[day.name]" />
                <span>Repeat for all days</span>
              </label>
            </template>

            <button
              @click="addStep(day.name)"
              class="text-white text-xs px-2 py-1 rounded"
              :style="selectedGoal ? `background-color: ${selectedGoal.color};` : ''"
            >
              Add
            </button>
          </div>
        </div>
      </template>
    </div>
  </div>
</div>

<!-- Alpine.js App Script -->
<script>
function plannerApp() {
  return {
    csrfToken: document.querySelector('meta[name="csrf-token"]').getAttribute('content'),
    calculateWeekStart(date) {
      const day = date.getDay();
      const diff = (day + 6) % 7;  // Convert Sunday (0) to 6, Monday (1) to 0, etc.
      const monday = new Date(date);
      monday.setDate(date.getDate() - diff);
      monday.setHours(0, 0, 0, 0); // Reset time
      return monday;
      },
    days: [
      { name: 'Monday', label: 'Monday' },
      { name: 'Tuesday', label: 'Tuesday' },
      { name: 'Wednesday', label: 'Wednesday' },
      { name: 'Thursday', label: 'Thursday' },
      { name: 'Friday', label: 'Friday' },
      { name: 'Saturday', label: 'Saturday' },
      { name: 'Sunday', label: 'Sunday' }
    ],

    allColors: ['#3b82f6', '#f59e0b', '#10b981', '#ef4444', '#8b5cf6', '#ec4899', '#22d3ee', '#14b8a6', '#eab308', '#6366f1', '#7c3aed', '#0ea5e9'],
    get availableColors() {
      const used = this.goals.map(g => g.color);
      return this.allColors.filter(c => !used.includes(c) || (this.editingGoal && this.goalForm.color === c));
    },

    goals: [],
    selectedGoalId: null,
    selectedGoal: null,
    selectedMilestone: null,
    weekOffset: 0,
    weekStartDate: null,
    weeklyPlan: {},
    newStep: {},
    newStepValue: {},
    repeatAllDays: {},
    dragData: null,
    dragOverDay: null,
    addingGoal: false,
    editingGoal: false,
    goalForm: { id: null, name: '', color: '', metric: '', target_value: '' },

    async init() {
      this.csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content');
      console.log('CSRF token:', this.csrfToken);
      this.days.forEach(day => {
        this.weeklyPlan[day.name] = [];
        this.days = this.getWeekDates();
        this.newStep[day.name] = '';
        this.newStepValue[day.name] = null;
        this.repeatAllDays[day.name] = false;
      });
      await this.fetchGoals();
    },

    getDateForDay(dayName) {
      const today = new Date();
      const dayIndex = ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'].indexOf(dayName);
      const offsetToMonday = (today.getDay() + 6) % 7;
      const startOfWeek = new Date(today);
      startOfWeek.setDate(today.getDate() - offsetToMonday + this.weekOffset * 7);

      const targetDate = new Date(startOfWeek);
      targetDate.setDate(startOfWeek.getDate() + ((dayIndex + 6) % 7));
      return targetDate.toISOString().split('T')[0];
    },
getWeekDates() {
  const today = new Date();
  const offsetToMonday = (today.getDay() + 6) % 7;
  const startOfWeek = new Date(today);
  startOfWeek.setDate(today.getDate() - offsetToMonday + this.weekOffset * 7);

  return this.days.map((day, index) => {
    const date = new Date(startOfWeek);
    date.setDate(startOfWeek.getDate() + index);
    return {
      ...day,
      dateFormatted: date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' }),
      fullDate: date.toISOString().split('T')[0],
    };
  });
},
    async selectMilestone(goal, milestone) {
      this.selectedGoal = goal;
      this.selectedGoalId = goal.id;
      this.selectedMilestone = milestone;
      this.weekOffset = 0;

      // Clear previous plan
      this.days.forEach(day => this.weeklyPlan[day.name] = []);

      await this.loadStepsForSelectedMilestone();
    },

    async loadStepsForSelectedMilestone() {
  if (!this.selectedMilestone) return;

  const res = await fetch(`/api/milestones/${this.selectedMilestone.id}/steps?week_offset=${this.weekOffset}`);
  const data = await res.json();
  if (!data.steps) {
    console.error("No steps returned for milestone.");
    return;
  }

  this.days.forEach(day => this.weeklyPlan[day.name] = []);
  for (const step of data.steps) {
    const date = new Date(step.date_for);
    const dayName = date.toLocaleDateString("en-US", { weekday: "long" });
    if (this.weeklyPlan[dayName]) {
      this.weeklyPlan[dayName].push(step);
    }
  }
},

    formatWeekRange() {
      if (!this.weekStartDate || isNaN(this.weekStartDate.getTime())) return "Invalid Date";
      const endDate = new Date(this.weekStartDate);
      endDate.setDate(endDate.getDate() + 6);
      const options = { month: 'short', day: 'numeric' };
      return `${this.weekStartDate.toLocaleDateString(undefined, options)} – ${endDate.toLocaleDateString(undefined, options)}`;
    },

    getWeekStartDateFormatted() {
      const today = new Date();
      const offsetToMonday = (today.getDay() + 6) % 7;
      const startOfWeek = new Date(today);
      startOfWeek.setDate(today.getDate() - offsetToMonday + this.weekOffset * 7);
      const options = { weekday: 'long', year: 'numeric', month: 'short', day: 'numeric' };
      return startOfWeek.toLocaleDateString(undefined, options);
    },

    async fetchGoals() {
      try {
        const res = await fetch('/api/goals/full');
        const data = await res.json();
        this.goals = data.map(goal => ({
          ...goal,
          expanded: false
        }));
      } catch (err) {
        console.error('Failed to fetch goals:', err);
      }
    },
prevWeek() {
  this.weekOffset--;
  this.days = this.getWeekDates();
  this.loadStepsForSelectedMilestone();
},

nextWeek() {
  this.weekOffset++;
  this.days = this.getWeekDates();
  this.loadStepsForSelectedMilestone();
},

changeWeek(offset) {
  this.weekOffset += offset;
  this.days = this.getWeekDates();
  this.loadStepsForSelectedMilestone();
},

goToCurrentWeek() {
  this.weekOffset = 0;
  this.days = this.getWeekDates();
  this.loadStepsForSelectedMilestone();
},

    async addStep(dayName) {
      const text = this.newStep[dayName]?.trim();
      const value = this.selectedMilestone?.metric ? this.newStepValue[dayName] : null;
      const repeat = this.repeatAllDays[dayName];

      if (text && this.selectedMilestone) {
        const addToDay = async (day) => {
          const payload = {
            title: text,
            value,
            completed: false,
            description: '',
            reflection: '',
            date_for: this.getDateForDay(day)
          };
          try {
            const res = await fetch(`/api/milestones/${this.selectedMilestone.id}/steps`, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'X-CSRFToken': this.csrfToken
              },
              body: JSON.stringify(payload)
            });
            const newStep = await res.json();
            this.weeklyPlan[day].push({ ...newStep, color: this.selectedMilestone.color });
          } catch (err) {
            console.error('Failed to add step:', err);
          }
        };

        if (this.selectedMilestone.metric || !repeat) {
          await addToDay(dayName);
        } else {
          for (const d of this.days) await addToDay(d.name);
        }

        this.newStep[dayName] = '';
        this.newStepValue[dayName] = null;
        this.repeatAllDays[dayName] = false;
      }
    },
    calculateWeekStart(date) {
        const day = date.getDay();
        const diff = (day + 6) % 7;  // Convert Sunday (0) to 6, Monday (1) to 0, etc.
        const monday = new Date(date);
        monday.setDate(date.getDate() - diff);
        monday.setHours(0, 0, 0, 0); // Normalize time
        return monday;
      },



    async removeStep(dayName, stepId) {
      try {
        await fetch(`/api/steps/${stepId}`, {
          method: 'DELETE',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': this.csrfToken
          }
        });
        this.weeklyPlan[dayName] = this.weeklyPlan[dayName].filter(s => s.id !== stepId);
      } catch (err) {
        console.error('Failed to delete step:', err);
      }
    },

    async toggleComplete(dayName, index, event) {
      const step = this.weeklyPlan[dayName][index];
      const newCompleted = event.target.checked;
      this.weeklyPlan[dayName][index].completed = newCompleted;
      try {
        const res = await fetch(`/api/steps/${step.id}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': this.csrfToken
          },
          body: JSON.stringify({ completed: newCompleted, title: step.title })
        });
        const updated = await res.json();
        this.weeklyPlan[dayName][index].completed = updated.completed;
      } catch (err) {
        console.error('Failed to toggle completion:', err);
        this.weeklyPlan[dayName][index].completed = !newCompleted;
      }
    },

    startDrag(dayName, index) {
      this.dragData = { fromDay: dayName, index };
    },

    async handleDrop(targetDayName) {
      const { fromDay, index } = this.dragData;
      const step = this.weeklyPlan[fromDay][index];
      const newDate = this.getDateForDay(targetDayName);
      try {
        const res = await fetch(`/api/steps/${step.id}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': this.csrfToken
          },
          body: JSON.stringify({ date_for: newDate, title: step.title })
        });
        const updated = await res.json();
        this.weeklyPlan[fromDay].splice(index, 1);
        this.weeklyPlan[targetDayName].push({ ...step, date_for: newDate });
        this.dragOverDay = null;
      } catch (err) {
        console.error('Failed to move step:', err);
      }
    }
  };
}
</script>

{% endblock %}
